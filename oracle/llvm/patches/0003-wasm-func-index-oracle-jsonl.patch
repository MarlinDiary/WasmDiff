+
+  // Ironclad binary<->linker join point:
+  // wasm-tools print exposes the module-level function index `(;N;)`.
+  // We log the same index along with the input chunk identifier so downstream
+  // tools can attribute "loc disappeared" cases to archive extraction/GC.
+  {
+    json::Object o;
+    o["kind"] = "func_index";
+    o["version"] = 1;
+    o["output"] = ctx.arg.outputFile;
+    o["index"] = static_cast<int64_t>(functionIndex);
+    o["chunk"] = toString(func);
+    if (func->file)
+      o["input_file"] = lld::toString(func->file);
+    o["symbol"] = func->name;
+    appendOracleJsonl(std::move(o));
+  }
